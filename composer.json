{
    "name": "oliverkroener/ok-typo3-helper",
    "type": "typo3-cms-extension",
    "description": "A TYPO3 extension with helper traits and utilities.",
    "authors": [
      {
        "name": "Oliver Kroener",
        "email": "ok@oliver-kroener.de"
      }
    ],
    "version": "2.0.0",
    "require": {
      "php": ">=7.2",
      "typo3/cms-core": "^10.4",
      "microsoft/microsoft-graph": "^1",
      "zbateson/mail-mime-parser": "^2"
    },
    "require-dev": {
      "typo3/coding-standards": "^0.5",
      "phpstan/phpstan": "^1.10",
      "saschaegerer/phpstan-typo3": "^1.1"
    },
    "autoload": {
      "psr-4": {
        "OliverKroener\\Helpers\\": "Classes/"
      }
    },
    "scripts": {
      "cs:check": "php-cs-fixer fix --config .php-cs-fixer.dist.php --dry-run --diff",
      "cs:fix": "php-cs-fixer fix --config .php-cs-fixer.dist.php",
      "stan": "phpstan analyse -c phpstan.neon",
      "stan:baseline": "phpstan analyse -c phpstan.neon --generate-baseline phpstan-baseline.neon"
    },
    "extra": {
      "typo3/cms": {
        "extension-key": "ok_typo3_helper"
      }
    },
    "license": "GPL-2.0-or-later",
    "config": {
        "policy": {
            "advisories": {
                "block": false
            }
        },
        "allow-plugins": {
            "typo3/cms-composer-installers": true,
            "typo3/class-alias-loader": true
        }
    }
}
